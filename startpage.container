[Unit]
Description=Browser startpage powered by nginx

[Container]
Image=docker.io/library/nginx
ContainerName=startpage
PublishPort=8282:80
Volume=/mnt/bigdrive/startpage/default.conf:/etc/nginx/conf.d/default.conf:Z
Volume=/mnt/bigdrive/startpage/html:/usr/share/nginx/html:Z

[Service]
Restart=always

[Install]
WantedBy=multi-user.target
